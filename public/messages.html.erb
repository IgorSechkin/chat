<% if @messages != nil %>
<% @messages.map() do |item| %>
<div style="background-color: lightyellow; border: solid; border-radius: 25px; margin-top: 20px; padding-left: 20px;">
<p style="padding-left: 20px;"><%= item[:time] %></p>
<p style="padding-left: 20px;"><%= item[:text] %></p>
</div>
<% end %>
<% end %>
